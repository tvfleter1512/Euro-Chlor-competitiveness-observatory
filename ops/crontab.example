# Observatory schedule — each source at its natural cadence (spec §6).
# Install with:  crontab ops/crontab.example   (after adjusting paths)
# All agents are idempotent and vintage-versioned; re-running is always safe.
P=/home/tva/Euro-Chlor-competitiveness-observatory/ops/run_agent.sh

# FX monthly averages — early morning daily (cheap; keeps current month fresh)
20 6 * * *   $P --agent ecb_fx

# ENTSO-E day-ahead — daily after price publication (~13:00-15:00 CET)
30 16 * * *  $P --agent entsoe_power

# EIA US industrial price — monthly
40 7 3 * *   $P --agent eia_power

# Eurostat nrg_pc_205 — semi-annual release; monthly check is ample
50 7 5 * *   $P --agent eurostat_power

# Comext trade — monthly, after the mid-month reference-period update
0 8 16 * *   $P --agent comext_trade

# UN Comtrade — monthly (annual data, but reporters trickle in)
15 8 17 * *  $P --agent comtrade_trade

# File-drop agents — daily pickup of any new curated/member files
0 7 * * *    $P --agent proxy_power
5 7 * * *    $P --agent eurochlor_drop

# Euro Chlor public monthly stats — first-of-month posts land early each month
30 8 * * 1   $P --agent eurochlor_web

# Gas hub prices (FRED monthly) + Eurostat nrg_pc_203 — monthly
45 7 4 * *   $P --agent gas_prices

# SunSirs China caustic spot — daily (page only shows ~6 days; cron accumulates)
15 7 * * *   $P --agent sunsirs_china

# EUA price (ICAP) + demand-side indicators (Eurostat STS) — monthly
0 9 6 * *    $P --agent eua_price
10 9 6 * *   $P --agent eurostat_demand

# PRODCOM + SBS (annual releases) — monthly check is ample
20 9 7 * *   $P --agent prodcom
30 9 7 * *   $P --agent eurostat_sbs

# Freight file-drop — daily pickup
20 7 * * *   $P --agent freight_drop

# Recompute all indicators nightly (fast; depends on everything above)
0 22 * * *   $P --benchmarks
