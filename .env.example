# Copy to .env and fill in. Never commit .env.
DATABASE_URL=postgresql://tva@localhost:5433/observatory

# --- API credentials (agents stay dormant until their key is present) ---
# ENTSO-E Transparency Platform: register at https://transparency.entsoe.eu,
# then email transparency@entsoe.eu with subject "Restful API access".
ENTSOE_TOKEN=

# UN Comtrade: register at https://comtradeplus.un.org, subscribe to the free API tier.
COMTRADE_KEY=

# US EIA: instant at https://www.eia.gov/opendata/register.php
EIA_KEY=

# --- App ---
API_HOST=0.0.0.0
API_PORT=8300
HISTORY_START=2015

# Dashboard password (HTTP Basic, any username). While set, member-restricted
# (redistribution_class='licensed') series are served; if empty, the app is
# open but licensed rows are hidden. Replace with proper member auth on the
# cloud deployment.
DASHBOARD_PASSWORD=
